# Rover control service config — copy to rover/.env and adjust.
# Backend = direct GPIO (gpiozero) driving an L298N. Pins are BCM GPIO numbers,
# defaults match docs/WIRING.md.

GPIOZERO_PIN_FACTORY=lgpio
ROVER_PORT=9000

# L298N motor pins: Motor A (left) IN1/IN2/EN, Motor B (right) IN3/IN4/EN
LEFT_IN1=17
LEFT_IN2=27
LEFT_EN=22
RIGHT_IN1=23
RIGHT_IN2=24
RIGHT_EN=25
ENC_LEFT=5
ENC_RIGHT=26

# Orientation calibration (set after the drive test):
#   INVERT_LEFT/RIGHT = -1 flips a wheel that spins the wrong way.
#   SWAP_SIDES=1 if left/right are physically swapped.
INVERT_LEFT=1
INVERT_RIGHT=1
SWAP_SIDES=0

# Safety limits (server clamps every command to these)
MAX_WHEEL_POWER=0.7
DEFAULT_DRIVE_SECONDS=1.0
MAX_DRIVE_SECONDS=3.0
MAX_MOVE_SECONDS=10
MAX_MOVE_M=3.0
MAX_TURN_DEG=360

# Open-loop calibration for discrete move/turn — MEASURED on this rover
# (CALIB_MPS from 23cm/2s @0.45; CALIB_DPS from 145deg/3s @0.45). Re-measure if
# wheels/battery/surface change.
MOVE_POWER=0.45
CALIB_MPS=0.115
TURN_POWER=0.45
CALIB_DPS=48

# ADXL345 accelerometer over I2C (optional)
I2C_BUS=1
ADXL345_ADDR=0x53
