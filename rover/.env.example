# Rover control service config — copy to rover/.env and fill in.
# Viam connection: get these from app.viam.com -> your machine -> CONNECT tab.
VIAM_ADDRESS=localhost:8080
VIAM_API_KEY=
VIAM_API_KEY_ID=

# Viam component names (must match your Viam config; confirm with the machine's
# config in app.viam.com or /etc/viam.json). Defaults match a typical Rover 1.
VIAM_BASE=viam_base
VIAM_MOVEMENT_SENSOR=accelerometer
VIAM_CAMERA=cam

# Service
ROVER_PORT=9000

# Safety limits (server clamps every command to these — the LLM can't exceed them)
MAX_LINEAR_POWER=0.6
MAX_ANGULAR_POWER=0.6
DEFAULT_DRIVE_SECONDS=1.0
MAX_DRIVE_SECONDS=3.0
MAX_MOVE_M=3.0
MAX_SPEED_MPS=0.5
DEFAULT_SPEED_MPS=0.3
MAX_TURN_DEG=360
DEFAULT_TURN_DPS=45
